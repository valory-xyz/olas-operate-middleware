#!/bin/bash

# Pre-push hook to run linting checks before pushing

echo "Running pre-push linting checks..."

poetry install && poetry run tox -p -e flake8 -e pylint && poetry run tox -p -e black-check -e isort-check -e bandit -e safety -e mypy -e safety
RESULT=$?

if [ $RESULT -ne 0 ]; then
    echo ""
    echo "Pre-push linting failed. Please fix the issues above before pushing."
    exit 1
fi

echo ""
echo "Pre-push linting passed!"
exit 0
